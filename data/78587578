SELECT E.DEPARTMENT_ID,
 D.DEPARTMENT_NAME,
 SUM(E.SALARY) TOTAL_SALARY
FROM EMPLOYEE E,
 DEPARTMENTS D
WHERE E.DEPARTMENT_ID = D.DEPARTMENT_ID
 AND E.MANAGER_ID is NULL
 AND D.LOCATION_ID = (SELECT LOCATION_ID
 FROM LOCATIONS
 WHERE CITY = 'SEOUL')
 AND SUM(E.SALARY) >= 100000
GROUP BY D.DEPARTMENT_NAME

